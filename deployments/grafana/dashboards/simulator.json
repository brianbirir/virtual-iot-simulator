{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Active Devices",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": "Prometheus",
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [
        { "expr": "sim_devices_active", "legendFormat": "Active", "refId": "A" }
      ]
    },
    {
      "id": 2,
      "title": "Messages / sec",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": "Prometheus",
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [
        { "expr": "rate(sim_messages_sent_total[1m])", "legendFormat": "msg/s", "refId": "A" }
      ]
    },
    {
      "id": 3,
      "title": "Active Faults",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": "Prometheus",
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [
        { "expr": "sum(sim_faults_injected_total)", "legendFormat": "Faults", "refId": "A" }
      ]
    },
    {
      "id": 4,
      "title": "Error Rate",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": "Prometheus",
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [
        { "expr": "rate(sim_device_errors_total[1m])", "legendFormat": "err/s", "refId": "A" }
      ]
    },
    {
      "id": 5,
      "title": "Backpressure Drops / sec",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "datasource": "Prometheus",
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [
        { "expr": "rate(sim_backpressure_drops_total[1m])", "legendFormat": "drops/s", "refId": "A" }
      ]
    },
    {
      "id": 10,
      "title": "Messages Sent (rate)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }
      },
      "targets": [
        { "expr": "rate(sim_messages_sent_total[1m])", "legendFormat": "{{protocol}}", "refId": "A" }
      ]
    },
    {
      "id": 11,
      "title": "Publish Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2 } }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(sim_publish_latency_seconds_bucket[1m]))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(sim_publish_latency_seconds_bucket[1m]))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, rate(sim_publish_latency_seconds_bucket[1m]))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "id": 12,
      "title": "Device Errors (rate)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }
      },
      "targets": [
        { "expr": "rate(sim_device_errors_total[1m])", "legendFormat": "{{device_type}}", "refId": "A" }
      ]
    },
    {
      "id": 13,
      "title": "Go Runtime",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 2 } }
      },
      "targets": [
        { "expr": "go_goroutines", "legendFormat": "goroutines", "refId": "A" },
        { "expr": "go_memstats_alloc_bytes", "legendFormat": "heap bytes", "refId": "B" }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "tags": ["iot-simulator"],
  "templating": { "list": [] },
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "IoT Simulator",
  "uid": "iot-simulator-v1",
  "version": 1
}
